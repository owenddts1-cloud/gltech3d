# =============================================================================
# GLTech3D — exemplo de variáveis de ambiente
# =============================================================================
# Copie para `.env.local` (que é gitignored) e preencha os valores reais.
# NUNCA commite `.env.local`. Fonte canônica de validação: lib/env.ts (Zod).
# =============================================================================

# ── Supabase (obrigatórias sempre, até em dev) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave admin (bypassa RLS) — só server-side, nunca exposta ao cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ── Chaves de criptografia (obrigatórias em produção) ────────────────────────
# CPF criptografado via pgcrypto.
CPF_ENCRYPTION_KEY=
# AES-256-GCM (32 bytes em base64) para credenciais de IA.
AI_CRED_AES_KEY=
# Cifra tokens BYO do WAHA.
WAHA_BYO_ENCRYPTION_KEY=
# Segredo interno para endpoints de cron/internos.
INTERNAL_SECRET=
INTERNAL_CRON_SECRET=

# ── WAHA (WhatsApp) — opcional; sem isto o Inbox degrada ─────────────────────
WAHA_API_BASE_URL=
WAHA_API_KEY=
WAHA_API_KEY_SHA512=
WAHA_HMAC_SECRET=
WAHA_WEBHOOK_BASE_URL=

# ── Webhook de telemetria de impressoras — opcional ──────────────────────────
# Segredo compartilhado do Klipper/OctoPrint (>= 8 chars). Sem isto, só o
# simulador logado (membro da org) consegue disparar o webhook.
PRINTER_WEBHOOK_SECRET=

# ── Email (Resend) — opcional ────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=GLTech3D <diretoria@seu-dominio.com.br>

# ── Instagram / Meta — opcional ──────────────────────────────────────────────
INSTAGRAM_WEBHOOK_SECRET=

# ── IA (opcional; worker degrada sem estas) ──────────────────────────────────
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
VERCEL_AI_GATEWAY_URL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Upstash Redis (rate limit) — opcional ────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Impersonate (admin) — opcional; >= 32 chars quando presente ──────────────
IMPERSONATE_COOKIE_SECRET=

# ── LGPD — opcional ──────────────────────────────────────────────────────────
LGPD_SIGNING_KEY=
LGPD_EXPORT_EXPIRES_HOURS=72
LGPD_DPO_EMAIL=

# ── Nuvemshop — opcional (só quando NUVEMSHOP_ENABLED=true) ───────────────────
NUVEMSHOP_ENABLED=false
NUVEMSHOP_APP_ID=
NUVEMSHOP_CLIENT_ID=
NUVEMSHOP_CLIENT_SECRET=
NUVEMSHOP_OAUTH_ENCRYPTION_KEY=

# ── Observabilidade / workers — opcional ─────────────────────────────────────
SENTRY_DSN=
EVENT_LOG_WORKER_ENABLED=false

# ── URLs da aplicação ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000
