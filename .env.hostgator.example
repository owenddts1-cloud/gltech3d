# =============================================================================
# DeskcommCRM — template de ambiente para self-host na HostGator (VPS + Docker).
# Copie para `.env` e preencha. O install.sh gera os segredos automaticamente.
#
# Regra de ouro:
#  - NEXT_PUBLIC_*  = embutidas no BUILD (baked na imagem). Trocar = REBUILD.
#  - as demais      = injetadas em RUNTIME pelo docker-compose (trocar = restart).
# =============================================================================

# -----------------------------------------------------------------------------
# 0) IMAGEM DO APP (imagem genérica pré-buildada — o leigo só puxa, não builda)
# -----------------------------------------------------------------------------
APP_IMAGE=ghcr.io/melgarafael/deskcommcrm:latest   # troque pelo seu fork se publicar o seu
APP_PULL_POLICY=always

# -----------------------------------------------------------------------------
# 1) DOMÍNIO / HTTPS (você define; aponte o A-record deste domínio pro IP do VPS)
# -----------------------------------------------------------------------------
DOMAIN=crm.seudominio.com.br
ACME_EMAIL=voce@seudominio.com.br          # e-mail do Let's Encrypt (avisos de cert)

# -----------------------------------------------------------------------------
# 2) SUPABASE (crie um projeto grátis em supabase.com → Settings → API/Database)
# -----------------------------------------------------------------------------
# BUILD-TIME (baked na imagem):
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=            # anon key (Settings → API)
# RUNTIME:
SUPABASE_SERVICE_ROLE_KEY=               # service_role key — BYPASSA RLS, só server
SUPABASE_DB_URL=                         # connection string (Settings → Database) — usada p/ baseline + bootstrap

# -----------------------------------------------------------------------------
# 3) APP URLs (BUILD-TIME — precisam bater com o DOMAIN acima; trocar = rebuild)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://crm.seudominio.com.br
NEXT_PUBLIC_ADMIN_URL=https://crm.seudominio.com.br

# -----------------------------------------------------------------------------
# 4) IA (Anthropic via AI Gateway) — paga por uso, chave sua
# -----------------------------------------------------------------------------
AI_GATEWAY_API_KEY=                      # ou ANTHROPIC_API_KEY abaixo
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                          # opcional — embeddings do RAG

# -----------------------------------------------------------------------------
# 5) SEGREDOS GERADOS PELO install.sh (openssl). NÃO precisa preencher à mão.
#    (comando de cada um ao lado, se quiser gerar manualmente)
# -----------------------------------------------------------------------------
INTERNAL_SECRET=                         # openssl rand -hex 32
INTERNAL_CRON_SECRET=                    # opcional; vazio = usa INTERNAL_SECRET
CPF_ENCRYPTION_KEY=                      # openssl rand -base64 32
AI_CRED_AES_KEY=                         # openssl rand -base64 32  (32 bytes)
WAHA_BYO_ENCRYPTION_KEY=                 # openssl rand -base64 32
IMPERSONATE_COOKIE_SECRET=               # openssl rand -hex 32  (>=32 chars)
LGPD_SIGNING_KEY=                        # openssl rand -hex 32

# -----------------------------------------------------------------------------
# 6) WhatsApp / WAHA  (Core grátis por padrão; ver docker-compose.prod.yml)
# -----------------------------------------------------------------------------
WAHA_API_BASE_URL=http://waha:3000       # nome do serviço na rede docker (não mexer)
WAHA_WEBHOOK_BASE_URL=http://app:3000    # WAHA→app interno; sem domínio público (não mexer)
WAHA_API_KEY=                            # gerado pelo install.sh (ver Task 6: hash vs plaintext)
WAHA_API_KEY_SHA512=                     # hash SHA512 hex de WAHA_API_KEY (o container usa este)
WAHA_HMAC_SECRET=                        # openssl rand -hex 32 (assinatura do webhook)

# -----------------------------------------------------------------------------
# 7) Redis (roda no VPS via serverless-redis-http; sem conta Upstash)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=http://srh:80     # container srh (não mexer)
UPSTASH_REDIS_REST_TOKEN=                # = SRH_TOKEN abaixo (mesmo valor)
SRH_TOKEN=                               # openssl rand -hex 32 (igual ao de cima)

# -----------------------------------------------------------------------------
# 8) FLAGS
# -----------------------------------------------------------------------------
NODE_ENV=production
NUVEMSHOP_ENABLED=false                  # template genérico; true p/ ligar e-commerce
INTERNAL_AGENT_RUN_STUB=false            # false = IA real (true devolveria trace fake!)

# -----------------------------------------------------------------------------
# 9) Nuvemshop (só preencher se NUVEMSHOP_ENABLED=true — partners.tiendanube.com)
# -----------------------------------------------------------------------------
NUVEMSHOP_APP_ID=
NUVEMSHOP_CLIENT_ID=
NUVEMSHOP_CLIENT_SECRET=
NUVEMSHOP_OAUTH_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# 10) E-mail transacional (Resend — opcional; sem ele, convites mostram link na UI)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# 11) Observabilidade (Sentry) — relatórios de erro
# -----------------------------------------------------------------------------
# Deixe VAZIO para enviar erros anonimizados ao Sentry da comunidade (ajuda a
# melhorar o CRM; CPF/telefone/e-mail são removidos antes do envio).
#   SENTRY_DSN=off          → desliga TODA a telemetria (nada é enviado)
#   SENTRY_DSN=<seu-dsn>    → envia os erros pro SEU próprio Sentry
SENTRY_DSN=

# -----------------------------------------------------------------------------
# 12) Bootstrap do 1º dono (usado só uma vez pelo install.sh)
# -----------------------------------------------------------------------------
OWNER_EMAIL=voce@seudominio.com.br
OWNER_PASSWORD=                          # senha forte do primeiro admin
